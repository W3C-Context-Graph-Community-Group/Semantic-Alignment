# Context Graph — ContextEvent Examples (Turtle 1.2)
#
# Status:  Non-normative working examples — v0.1
# Group:   W3C Context Graph Community Group
# Schema:  context-event-shapes.ttl
#
# Purpose
# -------
# This file provides conformant and non-conformant examples illustrating the
# ContextEvent SHACL 1.2 schema.  Each example is self-contained and can be
# validated independently against context-event-shapes.ttl.
#
# RDF 1.2 annotation syntax used
# --------------------------------
# Two equivalent notations are demonstrated:
#
#   (A)  Inline annotation  {| ... |}
#        The reifier node is anonymous and created implicitly:
#
#            ex:S  ex:p  ex:O
#                {| cg:producedByEvent ex:Evt |} .
#
#   (B)  Named reifier  ~ex:ReifierName
#        The reifier has an explicit IRI, enabling direct cross-reference:
#
#            ex:S  ex:p  ex:O  ~ex:ReifierName .
#            ex:ReifierName  cg:producedByEvent  ex:Evt .
#
# Both forms produce an RDF 1.2 reifier node shaped by
# cgsh:AssertionAnnotationShape.  Named reifiers (B) are preferred where the
# reifier itself needs to be referenced from other triples (e.g. linking a
# ResolutionTrace to a specific annotation).
#
# File structure
# --------------
#  §1  Shared vocabulary stubs  (agents, holons, credentials, concepts)
#  §2  CONFORMANT examples
#       C-01  DataEvent           — inline {| |} annotation
#       C-02  SpatialEvent        — inline {| |} annotation
#       C-03  PolicyEvent         — named reifier ~ex:R syntax
#       C-04  AuthEvent           — named reifier ~ex:R syntax
#       C-05  RelationEvent       — inline {| |} with composed intent
#       C-06  BoundaryEvent       — named reifier, multi-assertion
#  §3  NON-CONFORMANT examples  (each targets a specific violation)
#       NC-01  Missing mandatory facet          (cg:contextFacet absent)
#       NC-02  Temporal ordering violation      (endedAtTime < startedAtTime)
#       NC-03  Expired credential session       (commit after sessionValidUntil)
#       NC-04  SpatialEvent without coordinates (conditional sh:then violation)
#       NC-05  Non-SpatialEvent with coordinates(conditional sh:else violation)
#       NC-06  Invalid eventStatus assertion    (sh:in violation)
#       NC-07  Annotation missing producedByEvent (reifierShape violation)
#       NC-08  PolicyEvent missing modifiedPolicy (conditional sh:then violation)
#       NC-09  Coherence score out of range     (sh:maxInclusive violation)
#       NC-10  AuthEvent missing credentialLifecycleStatus

@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix prov:     <http://www.w3.org/ns/prov#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix geo:      <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix cg:       <https://w3c-context-graph-community-group.github.io/ns/context-graph#> .
@prefix cgsh:     <https://w3c-context-graph-community-group.github.io/ns/context-graph/shapes#> .
@prefix ex:       <https://example.org/cg-demo/> .


# ═══════════════════════════════════════════════════════════════════════════════
# §1  SHARED VOCABULARY STUBS
#     Minimal declarations of agents, holons, credentials, and concept scheme
#     entries referenced across all examples.  In a real deployment these would
#     live in separate named graphs.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Agents ────────────────────────────────────────────────────────────────────

ex:IngestServiceA  a prov:Agent ;
    rdfs:label "Ingest service account A" .

ex:PolicyAdminBot  a prov:Agent ;
    rdfs:label "Policy administration bot" .

ex:FieldSensorUnit7  a prov:Agent ;
    rdfs:label "Field sensor unit 7 (IoT device)" .

ex:AuthBroker  a prov:Agent ;
    rdfs:label "Authentication broker" .

ex:DataMigrationJob  a prov:Agent ;
    rdfs:label "Scheduled data migration job" .

ex:BoundaryController  a prov:Agent ;
    rdfs:label "Holon boundary controller" .

# ── Holons ────────────────────────────────────────────────────────────────────

ex:HolonExternalFeed   a owl:NamedIndividual ;
    rdfs:label "External data feed holon" .

ex:HolonContextGraph01 a owl:NamedIndividual ;
    rdfs:label "Context graph instance 01" .

ex:HolonKnowledgeLayer a owl:NamedIndividual ;
    rdfs:label "Knowledge graph layer holon" .

ex:HolonFieldOps       a owl:NamedIndividual ;
    rdfs:label "Field operations holon" .

# ── Boundaries ────────────────────────────────────────────────────────────────

ex:BoundaryIngestFeed   rdfs:label "Ingest feed → CG01" .
ex:BoundaryFieldOps     rdfs:label "Field ops → CG01" .
ex:BoundaryPolicyAdmin  rdfs:label "Policy admin → CG01" .
ex:BoundaryAuthBroker   rdfs:label "Auth broker → CG01" .
ex:BoundaryMigration    rdfs:label "Migration job → CG01" .
ex:BoundaryHolonCtrl    rdfs:label "Boundary controller → CG01" .

# ── Active credential sessions ────────────────────────────────────────────────
# sessionValidUntil is 2026-12-31 for all active sessions so that commit-time
# checks pass.  NC-03 uses an expired session to trigger a violation.

ex:CredIngestA  a owl:NamedIndividual ;
    rdfs:label "Ingest service credential (active)" .

ex:CredPolicyAdmin  a owl:NamedIndividual ;
    rdfs:label "Policy admin credential (active)" .

ex:CredFieldSensor  a owl:NamedIndividual ;
    rdfs:label "Field sensor credential (active)" .

ex:CredAuthBroker  a owl:NamedIndividual ;
    rdfs:label "Auth broker credential (active)" .

ex:CredMigration  a owl:NamedIndividual ;
    rdfs:label "Migration credential (active)" .

ex:CredExpired  a owl:NamedIndividual ;
    rdfs:label "Expired credential (used in NC-03)" .

ex:CredBoundaryCtrl  a owl:NamedIndividual ;
    rdfs:label "Boundary controller credential (active)" .

# ── SKOS event classification concepts ────────────────────────────────────────
# Stub entries; full ConceptScheme to be defined separately.

ex:ClassDataChange      a skos:Concept ; skos:prefLabel "Data change" .
ex:ClassSpatialReading  a skos:Concept ; skos:prefLabel "Spatial reading" .
ex:ClassPolicyChange    a skos:Concept ; skos:prefLabel "Policy change" .
ex:ClassAuthLifecycle   a skos:Concept ; skos:prefLabel "Auth lifecycle" .
ex:ClassRelationChange  a skos:Concept ; skos:prefLabel "Relation change" .
ex:ClassBoundaryChange  a skos:Concept ; skos:prefLabel "Boundary change" .

# ── Domain vocabulary stubs ───────────────────────────────────────────────────

ex:SensorOntology        a owl:Ontology ; rdfs:label "Sensor ontology" .
ex:TemperatureReading    a owl:Class    ; rdfs:label "Temperature reading" .
ex:HumidityReading       a owl:Class    ; rdfs:label "Humidity reading" .
ex:DeviceOntology        a owl:Ontology ; rdfs:label "Device ontology" .
ex:GeoFeatureOntology    a owl:Ontology ; rdfs:label "GeoFeature ontology" .
ex:PolicyOntology        a owl:Ontology ; rdfs:label "Policy ontology" .
ex:AccessControlPolicy   a owl:Class    ; rdfs:label "Access control policy" .
ex:HolonOntology         a owl:Ontology ; rdfs:label "Holon ontology" .
ex:HolonMembership       a owl:Class    ; rdfs:label "Holon membership" .

ex:ConstraintShape-ReadAccess  a sh:NodeShape ;
    rdfs:label "Read-access constraint shape" .

ex:TargetEntity   rdfs:label "Target entity" .
ex:SensorStation7 rdfs:label "Sensor station 7" .
ex:PolicyObject-ReadAccess  rdfs:label "Read access policy object" .
ex:PolicyVersion-ReadAccess-v1  rdfs:label "Read access policy v1" .
ex:SourceEntity   rdfs:label "Source entity (migration)" .
ex:TargetEntityB  rdfs:label "Target entity B" .
ex:SubsystemX     rdfs:label "Subsystem X" .
ex:HolonNewMember rdfs:label "Newly admitted holon member" .


# ═══════════════════════════════════════════════════════════════════════════════
# §2  CONFORMANT EXAMPLES
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# C-01  DataEvent — inline {| |} annotation
#
# The simplest conformant event: a temperature reading ingested from an external
# feed.  All four facets are present.  The ground assertion uses the inline
# annotation syntax; the reifier is anonymous.
#
# Demonstrates:
#   • Core ContextEventShape (all mandatory properties)
#   • Inline {| |} annotation → shaped by cgsh:AssertionAnnotationShape
#   • FacetCompletenessRule → cg:facetCompleteness 4
#   • EventStatusRule → cg:eventStatus cg:StatusValidated
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-C01  a cg:DataEvent ;

    cg:localId               "evt-c01-temperature-reading" ;

    prov:generatedAtTime     "2026-03-08T09:14:22Z"^^xsd:dateTimeStamp ;
    prov:startedAtTime       "2026-03-08T09:14:20Z"^^xsd:dateTimeStamp ;
    prov:endedAtTime         "2026-03-08T09:14:22Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:IngestServiceA ;
    cg:eventClassification   ex:ClassDataChange ;

    cg:producedAssertion     ex:TargetEntity ;

    cg:authenticationContext [
        cg:credentialId       ex:CredIngestA ;
        cg:credentialHolder   ex:IngestServiceA ;
        cg:sessionValidFrom   "2026-03-08T08:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeDataWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId             ex:BoundaryIngestFeed ;
        cg:sourceHolon            ex:HolonExternalFeed ;
        cg:targetHolon            ex:HolonContextGraph01 ;
        cg:boundaryCoherenceScore "0.95"^^xsd:decimal ;
    ] ;

    cg:dataFacet [
        cg:rawContent   "42.7" ;
        dcterms:format  <https://www.iana.org/assignments/media-types/text/plain> ;
        cg:contentHash  "a3f1b2c9d4e5f678901234567890abcd" ;
    ] ;

    cg:meaningFacet [
        cg:interpretedUnder  ex:SensorOntology ;
        cg:primaryConcept    ex:TemperatureReading ;
        rdfs:label           "Temperature reading" ;
    ] ;

    cg:structureFacet [
        cg:conformsToShape          cgsh:DataFacetShape ;
        cg:constraintEvaluationRecord [
            cg:evaluatedConstraint  cgsh:DataFacetShape ;
            cg:evaluationResult     cg:ResultPassed ;
        ] ;
    ] ;

    cg:contextFacet [
        cg:measuredCoherence  "0.92"^^xsd:decimal ;
        cg:resolutionStatus   cg:Resolved ;
        cg:prerequisite       ex:CredIngestA ;
    ] .

# Ground assertion — inline {| |} annotation syntax.
# The anonymous reifier is validated by cgsh:AssertionAnnotationShape.

ex:TargetEntity  cg:temperature  "42.7"
    {| cg:producedByEvent    ex:Event-C01 ;
       cg:assertedAt         "2026-03-08T09:14:22Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:IngestServiceA ;
       cg:assertionGraph     ex:HolonContextGraph01 ;
       cg:coherenceContribution "0.92"^^xsd:decimal |} .


# ───────────────────────────────────────────────────────────────────────────────
# C-02  SpatialEvent — inline {| |} annotation
#
# An IoT field sensor reports a geo-located humidity reading.
# Because the event is typed cg:SpatialEvent, the sh:if/sh:then conditional
# requires a cg:spatialContext node with geo:lat and geo:long.
#
# Demonstrates:
#   • sh:if/sh:then conditional (spatial branch)
#   • cgsh:SpatialContextShape (lat/long range constraints)
#   • Multiple {| |} annotations on different triples from the same event
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-C02  a cg:SpatialEvent ;

    cg:localId               "evt-c02-humidity-field" ;

    prov:generatedAtTime     "2026-03-08T10:05:00Z"^^xsd:dateTimeStamp ;
    prov:startedAtTime       "2026-03-08T10:04:58Z"^^xsd:dateTimeStamp ;
    prov:endedAtTime         "2026-03-08T10:05:00Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:FieldSensorUnit7 ;
    cg:eventClassification   ex:ClassSpatialReading ;

    cg:producedAssertion     ex:SensorStation7 ;

    cg:authenticationContext [
        cg:credentialId       ex:CredFieldSensor ;
        cg:credentialHolder   ex:FieldSensorUnit7 ;
        cg:sessionValidFrom   "2026-03-08T06:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeDataWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId             ex:BoundaryFieldOps ;
        cg:sourceHolon            ex:HolonFieldOps ;
        cg:targetHolon            ex:HolonContextGraph01 ;
        cg:boundaryCoherenceScore "0.87"^^xsd:decimal ;
    ] ;

    # Spatial context — required by the cg:SpatialEvent conditional
    cg:spatialContext [
        geo:lat                       "51.5074"^^xsd:decimal ;
        geo:long                      "-0.1278"^^xsd:decimal ;
        cg:spatialPrecisionMetres     "5.0"^^xsd:decimal ;
        cg:spatialReferenceSystem     <http://www.opengis.net/def/crs/EPSG/0/4326> ;
    ] ;

    cg:dataFacet [
        cg:rawContent   "78.3" ;
        dcterms:format  <https://www.iana.org/assignments/media-types/text/plain> ;
    ] ;

    cg:meaningFacet [
        cg:interpretedUnder  ex:SensorOntology ;
        cg:primaryConcept    ex:HumidityReading ;
        rdfs:label           "Relative humidity reading" ;
    ] ;

    cg:structureFacet [
        cg:conformsToShape  cgsh:DataFacetShape ;
    ] ;

    cg:contextFacet [
        cg:measuredCoherence  "0.88"^^xsd:decimal ;
        cg:resolutionStatus   cg:Resolved ;
        cg:prerequisite       ex:CredFieldSensor ;
        cg:prerequisite       <http://www.opengis.net/def/crs/EPSG/0/4326> ;
    ] .

# Two ground assertions from the same event, both annotated inline.
# Note that a single event may produce multiple assertions.

ex:SensorStation7  cg:humidityPercent  "78.3"
    {| cg:producedByEvent    ex:Event-C02 ;
       cg:assertedAt         "2026-03-08T10:05:00Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:FieldSensorUnit7 ;
       cg:assertionGraph     ex:HolonContextGraph01 |} .

ex:SensorStation7  geo:lat  "51.5074"^^xsd:decimal
    {| cg:producedByEvent    ex:Event-C02 ;
       cg:assertedAt         "2026-03-08T10:05:00Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:FieldSensorUnit7 ;
       cg:assertionGraph     ex:HolonContextGraph01 |} .


# ───────────────────────────────────────────────────────────────────────────────
# C-03  PolicyEvent — named reifier ~ex:R syntax
#
# The policy administration bot modifies a read-access constraint shape.
# The named reifier syntax is preferred here because the ResolutionTrace (stub)
# needs to reference the specific annotation node that recorded this change.
#
# Demonstrates:
#   • Named reifier syntax:  ex:Subject  ex:p  ex:O  ~ex:ReifierIRI .
#   • cgsh:PolicyChangeRequiredShape (conditional sh:then for PolicyEvent)
#   • Reifier IRI used as a direct target in a separate triple
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-C03  a cg:PolicyEvent ;

    cg:localId               "evt-c03-policy-update" ;

    prov:generatedAtTime     "2026-03-08T11:30:00Z"^^xsd:dateTimeStamp ;
    prov:startedAtTime       "2026-03-08T11:29:55Z"^^xsd:dateTimeStamp ;
    prov:endedAtTime         "2026-03-08T11:30:00Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:PolicyAdminBot ;
    cg:eventClassification   ex:ClassPolicyChange ;

    cg:producedAssertion     ex:PolicyObject-ReadAccess ;

    # PolicyEvent-specific fields (cgsh:PolicyChangeRequiredShape)
    cg:modifiedPolicy        ex:PolicyObject-ReadAccess ;
    cg:priorPolicyVersion    ex:PolicyVersion-ReadAccess-v1 ;

    cg:authenticationContext [
        cg:credentialId       ex:CredPolicyAdmin ;
        cg:credentialHolder   ex:PolicyAdminBot ;
        cg:sessionValidFrom   "2026-03-08T11:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopePolicyWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId   ex:BoundaryPolicyAdmin ;
        cg:sourceHolon  ex:HolonExternalFeed ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet [
        cg:rawContent   "{ op: 'replace', path: '/minCount', value: 2 }" ;
        dcterms:format  <https://www.iana.org/assignments/media-types/application/json-patch+json> ;
    ] ;

    cg:meaningFacet [
        cg:interpretedUnder  ex:PolicyOntology ;
        cg:primaryConcept    ex:AccessControlPolicy ;
        rdfs:label           "Read-access policy update" ;
    ] ;

    cg:structureFacet [
        cg:conformsToShape  cgsh:ContextEventShape ;
    ] ;

    cg:contextFacet [
        cg:measuredCoherence  "1.0"^^xsd:decimal ;
        cg:resolutionStatus   cg:Resolved ;
    ] .

# Ground assertion using named reifier syntax.
# ex:Reifier-C03 is an explicit IRI; it can be referenced from other triples.

ex:PolicyObject-ReadAccess  cg:policyVersion  "v2"
    ~ex:Reifier-C03 .

ex:Reifier-C03
    cg:producedByEvent    ex:Event-C03 ;
    cg:assertedAt         "2026-03-08T11:30:00Z"^^xsd:dateTimeStamp ;
    cg:assertionAuthority ex:PolicyAdminBot ;
    cg:assertionGraph     ex:HolonContextGraph01 .

# The named reifier can now be cross-referenced: here from a stub resolution
# trace to record exactly which annotation captured the policy change.

ex:ResolutionTrace-C03
    a cg:ResolutionTrace ;
    cg:traceId      ex:ResolutionTrace-C03 ;
    cg:traceEvents  ex:Event-C03 ;
    cg:traceOutcome cg:TraceResolved ;
    cg:trackedAnnotation  ex:Reifier-C03 .   # ← direct named-reifier reference


# ───────────────────────────────────────────────────────────────────────────────
# C-04  AuthEvent — named reifier syntax
#
# The authentication broker submits a credential for a new session.
# AuthEvents may have a minimal data payload; the credential itself is the
# primary content.  Named reifier used so the session record can reference
# the specific annotation that established the session.
#
# Demonstrates:
#   • cgsh:AuthEventRequiredShape (cg:credentialLifecycleStatus mandatory)
#   • cg:CredentialSubmitted lifecycle status
#   • Named reifier cross-referenced from the authentication context itself
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-C04  a cg:AuthEvent ;

    cg:localId               "evt-c04-session-open" ;

    prov:generatedAtTime     "2026-03-08T08:00:01Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:AuthBroker ;
    cg:eventClassification   ex:ClassAuthLifecycle ;

    cg:credentialLifecycleStatus  cg:CredentialSubmitted ;

    # AuthEvents still require producedAssertion — here it is the session record.
    # [OPEN] The group should decide if cg:AuthEvent warrants a minCount 0 exemption.
    cg:producedAssertion     ex:Session-C04 ;

    cg:authenticationContext [
        cg:credentialId       ex:CredAuthBroker ;
        cg:credentialHolder   ex:AuthBroker ;
        cg:sessionValidFrom   "2026-03-08T08:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeAuthWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId   ex:BoundaryAuthBroker ;
        cg:sourceHolon  ex:HolonExternalFeed ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet [
        cg:rawContent  "credential-submission-payload" ;
    ] ;

    cg:meaningFacet [
        cg:interpretedUnder  ex:DeviceOntology ;
        cg:primaryConcept    ex:AuthBroker ;
        rdfs:label           "Session open" ;
    ] ;

    cg:structureFacet [
        cg:conformsToShape  cgsh:ContextEventShape ;
    ] ;

    cg:contextFacet [
        cg:measuredCoherence  "1.0"^^xsd:decimal ;
        cg:resolutionStatus   cg:Resolved ;
    ] .

# Named reifier for the session assertion.
ex:Session-C04  cg:sessionStatus  cg:CredentialSubmitted
    ~ex:Reifier-C04 .

ex:Reifier-C04
    cg:producedByEvent    ex:Event-C04 ;
    cg:assertedAt         "2026-03-08T08:00:01Z"^^xsd:dateTimeStamp ;
    cg:assertionAuthority ex:AuthBroker ;
    cg:assertionGraph     ex:HolonContextGraph01 .


# ───────────────────────────────────────────────────────────────────────────────
# C-05  RelationEvent — inline {| |} with composed intent
#
# A data migration job asserts a new relationship between two entities.
# The intent is recorded as cg:ComposedIntent because it derives from both
# the job's configuration and a subsystem constraint.
#
# Demonstrates:
#   • cg:RelationEvent subtype
#   • cgsh:IntentShape with intentEvidence linking back to prior events
#   • cg:precedingEvent trail link
#   • Inline {| |} on a relationship triple
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-C05  a cg:RelationEvent ;

    cg:localId               "evt-c05-migration-relation" ;

    prov:generatedAtTime     "2026-03-08T13:00:10Z"^^xsd:dateTimeStamp ;
    prov:startedAtTime       "2026-03-08T13:00:08Z"^^xsd:dateTimeStamp ;
    prov:endedAtTime         "2026-03-08T13:00:10Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:DataMigrationJob ;
    cg:eventClassification   ex:ClassRelationChange ;

    cg:producedAssertion     ex:TargetEntityB ;

    # Event trail — this event follows C-01 in the same session
    cg:precedingEvent        ex:Event-C01 ;

    cg:authenticationContext [
        cg:credentialId       ex:CredMigration ;
        cg:credentialHolder   ex:DataMigrationJob ;
        cg:sessionValidFrom   "2026-03-08T13:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeDataWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId   ex:BoundaryMigration ;
        cg:sourceHolon  ex:HolonExternalFeed ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet [
        cg:rawContent  "source=ex:SourceEntity target=ex:TargetEntityB rel=cg:migratedFrom" ;
    ] ;

    cg:meaningFacet [
        cg:interpretedUnder  ex:DeviceOntology ;
        cg:primaryConcept    ex:HolonMembership ;
        rdfs:label           "Migration source–target relationship" ;
    ] ;

    cg:structureFacet [
        cg:conformsToShape  cgsh:ContextEventShape ;
    ] ;

    cg:contextFacet [
        cg:measuredCoherence  "0.79"^^xsd:decimal ;
        cg:resolutionStatus   cg:PartiallyResolved ;

        # Composed intent: derived from job config + subsystem constraint
        cg:attributedIntent [
            cg:intentType         cg:ComposedIntent ;
            cg:intentDescription  "Migrate source–target association per job config and subsystem constraint" ;
            cg:intentEvidence     ex:Event-C01 ;         # prior event in the trail
            cg:intentEvidence     ex:SubsystemX ;        # subsystem constraint source
        ] ;
    ] .

# Inline annotation on the relationship triple.
ex:TargetEntityB  cg:migratedFrom  ex:SourceEntity
    {| cg:producedByEvent    ex:Event-C05 ;
       cg:assertedAt         "2026-03-08T13:00:10Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:DataMigrationJob ;
       cg:assertionGraph     ex:HolonContextGraph01 ;
       cg:coherenceContribution "0.79"^^xsd:decimal |} .


# ───────────────────────────────────────────────────────────────────────────────
# C-06  BoundaryEvent — named reifier, multiple assertions
#
# The boundary controller adds a new holon member to an existing boundary
# definition.  Two separate ground assertions are produced and recorded with
# distinct named reifiers, enabling independent resolution trace references.
#
# Demonstrates:
#   • cg:BoundaryEvent subtype
#   • Multiple cg:producedAssertion values with distinct named reifiers
#   • Both assertions referencing the same event
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-C06  a cg:BoundaryEvent ;

    cg:localId               "evt-c06-boundary-membership" ;

    prov:generatedAtTime     "2026-03-08T14:00:00Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:BoundaryController ;
    cg:eventClassification   ex:ClassBoundaryChange ;

    # Two assertions produced — membership and boundary update record
    cg:producedAssertion     ex:HolonNewMember ;
    cg:producedAssertion     ex:BoundaryIngestFeed ;

    cg:authenticationContext [
        cg:credentialId       ex:CredBoundaryCtrl ;
