        cg:sourceHolon  ex:HolonFieldOps ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet    [ cg:rawContent "100.0" ] ;
    cg:meaningFacet [ cg:interpretedUnder ex:SensorOntology ; rdfs:label "Altitude" ] ;
    cg:structureFacet [ cg:conformsToShape cgsh:DataFacetShape ] ;
    cg:contextFacet [
        cg:measuredCoherence "0.6"^^xsd:decimal ;
        cg:resolutionStatus  cg:PartiallyResolved ;
    ] .

ex:SensorStation7  cg:altitude  "100.0"
    {| cg:producedByEvent    ex:Event-NC04 ;
       cg:assertedAt         "2026-03-08T10:10:00Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:FieldSensorUnit7 ;
       cg:assertionGraph     ex:HolonContextGraph01 |} .


# ───────────────────────────────────────────────────────────────────────────────
# NC-05  Non-SpatialEvent with spatial coordinates
#
# Expected violation:
#   cgsh:SpatialEventConditional  sh:else  cgsh:SpatialContextAbsentShape
#   → "cg:spatialContext should not appear on a ContextEvent not typed cg:SpatialEvent."
#
# The event is a plain cg:DataEvent but carries cg:spatialContext.
# The sh:if test fails (not a SpatialEvent), so sh:else fires and requires
# cg:spatialContext to be absent (sh:maxCount 0); it is present → violation.
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-NC05  a cg:DataEvent ;   # ← not a SpatialEvent

    cg:localId               "evt-nc05-data-with-spurious-coords" ;

    prov:generatedAtTime     "2026-03-08T10:15:00Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:IngestServiceA ;
    cg:eventClassification   ex:ClassDataChange ;
    cg:producedAssertion     ex:TargetEntity ;

    # cg:spatialContext present on a non-SpatialEvent → violation
    cg:spatialContext [
        geo:lat   "51.5074"^^xsd:decimal ;
        geo:long  "-0.1278"^^xsd:decimal ;
    ] ;

    cg:authenticationContext [
        cg:credentialId       ex:CredIngestA ;
        cg:credentialHolder   ex:IngestServiceA ;
        cg:sessionValidFrom   "2026-03-08T08:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeDataWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId   ex:BoundaryIngestFeed ;
        cg:sourceHolon  ex:HolonExternalFeed ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet    [ cg:rawContent "7.2" ] ;
    cg:meaningFacet [ cg:interpretedUnder ex:SensorOntology ; rdfs:label "pH reading" ] ;
    cg:structureFacet [ cg:conformsToShape cgsh:DataFacetShape ] ;
    cg:contextFacet [
        cg:measuredCoherence "0.9"^^xsd:decimal ;
        cg:resolutionStatus  cg:Resolved ;
    ] .

ex:TargetEntity  cg:pH  "7.2"
    {| cg:producedByEvent    ex:Event-NC05 ;
       cg:assertedAt         "2026-03-08T10:15:00Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:IngestServiceA ;
       cg:assertionGraph     ex:HolonContextGraph01 |} .


# ───────────────────────────────────────────────────────────────────────────────
