# ───────────────────────────────────────────────────────────────────────────────
# NC-07  Annotation reifier missing cg:producedByEvent
#
# Expected violation:
#   cgsh:AssertionAnnotationShape  sh:property
#     [ sh:path cg:producedByEvent ; sh:minCount 1 ]
#   → "Every annotated assertion must link back to the cg:ContextEvent that
#      produced it."
#
# The named reifier ex:Reifier-NC07 omits cg:producedByEvent entirely.
# This is the core SHACL 1.2 sh:reifierShape test: the shape must be
# enforced on the reifier node regardless of the triple it annotates.
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-NC07  a cg:DataEvent ;

    cg:localId               "evt-nc07-orphan-reifier" ;

    prov:generatedAtTime     "2026-03-08T09:50:00Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:IngestServiceA ;
    cg:eventClassification   ex:ClassDataChange ;
    cg:producedAssertion     ex:TargetEntity ;

    cg:authenticationContext [
        cg:credentialId       ex:CredIngestA ;
        cg:credentialHolder   ex:IngestServiceA ;
        cg:sessionValidFrom   "2026-03-08T08:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeDataWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId   ex:BoundaryIngestFeed ;
        cg:sourceHolon  ex:HolonExternalFeed ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet    [ cg:rawContent "3.14" ] ;
    cg:meaningFacet [ cg:interpretedUnder ex:SensorOntology ; rdfs:label "Pi approximation" ] ;
    cg:structureFacet [ cg:conformsToShape cgsh:DataFacetShape ] ;
    cg:contextFacet [
        cg:measuredCoherence "0.9"^^xsd:decimal ;
        cg:resolutionStatus  cg:Resolved ;
    ] .

# Named reifier is missing cg:producedByEvent → cgsh:AssertionAnnotationShape violation.
ex:TargetEntity  cg:piValue  "3.14"
    ~ex:Reifier-NC07 .

ex:Reifier-NC07
    # cg:producedByEvent intentionally omitted
    cg:assertedAt         "2026-03-08T09:50:00Z"^^xsd:dateTimeStamp ;
    cg:assertionAuthority ex:IngestServiceA ;
    cg:assertionGraph     ex:HolonContextGraph01 .


