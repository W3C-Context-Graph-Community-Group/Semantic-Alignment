# ═══════════════════════════════════════════════════════════════════════════════
# §3  NON-CONFORMANT EXAMPLES
#     Each example below is invalid against context-event-shapes.ttl.
#     The expected violation is stated in the comment header of each block.
#     The event IRI carries the prefix "nc-" to make identification easy.
#
#     IMPORTANT: these events share no data with the conformant examples above.
#     Each is self-contained. Validators will report violations on the nc-
#     events only.
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# NC-01  Missing mandatory facet
#
# Expected violation:
#   cgsh:ContextEventShape  sh:property [ sh:path cg:contextFacet ; sh:minCount 1 ]
#   → "A ContextEvent must have exactly one cg:contextFacet."
#
# cg:contextFacet is absent. All other facets are present. The
# FacetCompletenessRule will derive cg:facetCompleteness 3, causing
# EventStatusRule to derive cg:eventStatus cg:StatusFailed.
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-NC01  a cg:DataEvent ;

    cg:localId               "evt-nc01-missing-context-facet" ;

    prov:generatedAtTime     "2026-03-08T09:20:00Z"^^xsd:dateTimeStamp ;

    cg:initiatedBy           ex:IngestServiceA ;
    cg:eventClassification   ex:ClassDataChange ;
    cg:producedAssertion     ex:TargetEntity ;

    cg:authenticationContext [
        cg:credentialId       ex:CredIngestA ;
        cg:credentialHolder   ex:IngestServiceA ;
        cg:sessionValidFrom   "2026-03-08T08:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeDataWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId   ex:BoundaryIngestFeed ;
        cg:sourceHolon  ex:HolonExternalFeed ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet [
        cg:rawContent  "55.1" ;
    ] ;

    cg:meaningFacet [
        cg:interpretedUnder  ex:SensorOntology ;
        rdfs:label           "Pressure reading" ;
    ] ;

    cg:structureFacet [
        cg:conformsToShape  cgsh:DataFacetShape ;
    ] .

# ← cg:contextFacet is intentionally absent.

ex:TargetEntity  cg:pressure  "55.1"
    {| cg:producedByEvent    ex:Event-NC01 ;
       cg:assertedAt         "2026-03-08T09:20:00Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:IngestServiceA ;
       cg:assertionGraph     ex:HolonContextGraph01 |} .


# ───────────────────────────────────────────────────────────────────────────────
# NC-02  Temporal ordering violation
#
# Expected violation:
#   cgsh:ContextEventShape  sh:sparql (temporal ordering check)
#   → "prov:endedAtTime must not precede prov:startedAtTime."
#
# prov:endedAtTime is set to 30 seconds BEFORE prov:startedAtTime.
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-NC02  a cg:DataEvent ;

    cg:localId               "evt-nc02-time-inversion" ;

    prov:generatedAtTime     "2026-03-08T09:30:00Z"^^xsd:dateTimeStamp ;
    prov:startedAtTime       "2026-03-08T09:30:00Z"^^xsd:dateTimeStamp ;
    prov:endedAtTime         "2026-03-08T09:29:30Z"^^xsd:dateTimeStamp ;  # ← before start

    cg:initiatedBy           ex:IngestServiceA ;
    cg:eventClassification   ex:ClassDataChange ;
    cg:producedAssertion     ex:TargetEntity ;

    cg:authenticationContext [
        cg:credentialId       ex:CredIngestA ;
        cg:credentialHolder   ex:IngestServiceA ;
        cg:sessionValidFrom   "2026-03-08T08:00:00Z"^^xsd:dateTimeStamp ;
        cg:sessionValidUntil  "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp ;
        cg:permissionScope    cg:ScopeDataWrite ;
    ] ;

    cg:atBoundary [
        cg:boundaryId   ex:BoundaryIngestFeed ;
        cg:sourceHolon  ex:HolonExternalFeed ;
        cg:targetHolon  ex:HolonContextGraph01 ;
    ] ;

    cg:dataFacet    [ cg:rawContent "1.0" ] ;
    cg:meaningFacet [ cg:interpretedUnder ex:SensorOntology ; rdfs:label "Voltage" ] ;
    cg:structureFacet [ cg:conformsToShape cgsh:DataFacetShape ] ;
    cg:contextFacet [
        cg:measuredCoherence "0.9"^^xsd:decimal ;
        cg:resolutionStatus  cg:Resolved ;
    ] .

ex:TargetEntity  cg:voltage  "1.0"
    {| cg:producedByEvent    ex:Event-NC02 ;
       cg:assertedAt         "2026-03-08T09:30:00Z"^^xsd:dateTimeStamp ;
       cg:assertionAuthority ex:IngestServiceA ;
       cg:assertionGraph     ex:HolonContextGraph01 |} .


# ───────────────────────────────────────────────────────────────────────────────
# NC-03  Expired credential session
#
# Expected violation:
#   cgsh:AuthenticationContextShape  sh:sparql (session expiry check)
#   → "The credential session had expired before this event was committed."
#
# prov:generatedAtTime (09:14:22) is after cg:sessionValidUntil (08:00:00)
# on the same day — the session had already expired.
# ───────────────────────────────────────────────────────────────────────────────

ex:Event-NC03  a cg:DataEvent ;

    cg:localId               "evt-nc03-expired-session" ;

